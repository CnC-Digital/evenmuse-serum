# ─────────────────────────────────────────────────────────────
# EvenMuse Serum — Environment Variables (TEMPLATE)
#
# HOW TO FIND YOUR IDs IN PANCAKE POS:
#   Shop ID     → log in to pos.pancake.ph → check the URL
#                 e.g. pos.pancake.ph/shop/12345 → Shop ID is 12345
#
#   Product IDs → go to Products → click a product → check the URL
#                 e.g. pos.pancake.ph/shop/.../products/67890 → ID is 67890
#
# Copy these values to: Netlify → Site → Environment Variables
# ─────────────────────────────────────────────────────────────

# ── Meta / Facebook ──────────────────────────────────────────
FB_PIXEL_ID=
FB_ACCESS_TOKEN=
FB_TEST_EVENT_CODE=

# ── Pancake POS ───────────────────────────────────────────────
PANCAKE_API_KEY=
PANCAKE_SHOP_ID=

# Product IDs — copy from each product's URL in POS dashboard
PANCAKE_PRODUCT_ID_1PC=
PANCAKE_PRODUCT_ID_2PC=
PANCAKE_PRODUCT_ID_3PC=

# ── Botcake ───────────────────────────────────────────────────
BOTCAKE_WEBHOOK_URL=
BOTCAKE_MESSENGER_URL=
