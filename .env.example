# Meta / Facebook
FB_PIXEL_ID=                      # FB Pixel ID (also used client-side)
FB_ACCESS_TOKEN=                  # Meta CAPI access token
FB_TEST_EVENT_CODE=               # Optional: for testing CAPI events in Events Manager

# Pancake POS
PANCAKE_API_KEY=                  # Pancake POS API key
PANCAKE_API_URL=                  # Pancake POS base URL (e.g., https://pos.pancake.vn/api/v1)
PANCAKE_SHOP_ID=                  # Pancake shop ID

# Pancake Product Mapping (JSON string)
# Maps landing page package names to Pancake POS product IDs
PANCAKE_PRODUCT_MAP={"starter_glow":"","bestie_pack":"","squad_pack":""}

# Botcake
BOTCAKE_WEBHOOK_URL=              # Botcake webhook endpoint URL
BOTCAKE_MESSENGER_URL=            # Messenger redirect URL shown on Thank You page
