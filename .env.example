# ─────────────────────────────────────────────────────────────
# EvenMuse Serum — Environment Variables (TEMPLATE)
# Copy these to: Netlify → Site → Environment Variables
# ─────────────────────────────────────────────────────────────

# ── Meta / Facebook ──────────────────────────────────────────
FB_PIXEL_ID=
FB_ACCESS_TOKEN=
FB_TEST_EVENT_CODE=

# ── Pancake POS (required) ────────────────────────────────────
PANCAKE_API_KEY=
PANCAKE_SHOP_ID=

# ── Pancake POS (optional overrides) ─────────────────────────
# Only fill these if auto-detection does not work.
# The backend will auto-find product & variant IDs from the API.
PANCAKE_API_URL=
PANCAKE_PRODUCT_ID=
PANCAKE_VARIANT_ID_1PC=
PANCAKE_VARIANT_ID_2PC=
PANCAKE_VARIANT_ID_3PC=

# ── Botcake ───────────────────────────────────────────────────
BOTCAKE_WEBHOOK_URL=
BOTCAKE_MESSENGER_URL=
