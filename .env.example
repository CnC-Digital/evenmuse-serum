# ─────────────────────────────────────────────────────────────
# EvenMuse Serum — Environment Variables (TEMPLATE)
# Copy these to: Netlify → Site → Environment Variables
# ─────────────────────────────────────────────────────────────

# ── Meta Conversions API (server-side) ───────────────────────
FB_PIXEL_ID=
FB_ACCESS_TOKEN=
# Optional: only needed when testing via Events Manager
FB_TEST_EVENT_CODE=

# ── Pancake POS (required) ────────────────────────────────────
PANCAKE_API_KEY=
PANCAKE_SHOP_ID=

# ── Pancake POS — Product/Variation IDs ──────────────────────
# Run /api/pancake-products to get these IDs from your shop.
PANCAKE_PRODUCT_ID_1PC=
PANCAKE_VARIATION_ID_1PC=
PANCAKE_PRODUCT_ID_2PC=
PANCAKE_VARIATION_ID_2PC=
PANCAKE_PRODUCT_ID_3PC=
PANCAKE_VARIATION_ID_3PC=

# ── Botcake Dynamic Block ─────────────────────────────────────
# In your Botcake flow, add a Dynamic Block and set the URL to:
#   https://YOUR_NETLIFY_SITE/api/botcake-order
#
# Botcake will POST subscriber data (including phone) to that URL.
# The server looks up the pending order by phone (stored for 2h)
# and returns the full order confirmation message automatically.
# No additional env vars needed — uses Netlify Blobs automatically.
